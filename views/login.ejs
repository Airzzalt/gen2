<!doctype html>
<html lang="en">
<head>
<%- include("partials/head", { brand, title: "Log in" }) %>
</head>
<body>
  <div class="dot-field"></div>
  <div class="auth-shell">
    <div class="auth-topbar"><a class="back-link" href="/"><%= brand %></a></div>
    <div class="auth-card">
      <%- include("partials/logo", { size: 52 }) %>
      <h1>Welcome back</h1>
      <p class="sub">New here? <a href="/signup">Create a free account</a>.</p>
      <form class="auth-form" id="loginForm">
        <div class="field">
          <label>Email</label>
          <input class="input" id="email" type="email" autocomplete="email" placeholder="you@example.com" required />
        </div>
        <div class="field">
          <label>Password</label>
          <input class="input" id="password" type="password" autocomplete="current-password" placeholder="Your password" required />
        </div>
        <div class="error-text" id="errorText"></div>
        <button class="btn btn-primary btn-block" id="submitBtn" type="submit">Log in</button>
      </form>
      <p class="auth-foot-note">
        By continuing you agree this account may be limited to a set number of free receipt
        generates per month. Need more? Email <a href="mailto:kapeairzz7@gmail.com">kapeairzz7@gmail.com</a>.
      </p>
    </div>
  </div>
  <script src="/public/js/common.js"></script>
  <script src="/public/js/login.js"></script>
</body>
</html>

<!doctype html>
<html lang="en">
<head>
<%- include("partials/head", { brand, title: "Sign up" }) %>
</head>
<body>
  <div class="dot-field"></div>
  <div class="auth-shell">
    <div class="auth-topbar"><a class="back-link" href="/"><%= brand %></a></div>
    <div class="auth-card">
      <%- include("partials/logo", { size: 52 }) %>
      <h1>Create your account</h1>
      <p class="sub">Already have one? <a href="/login">Log in</a>.</p>
      <form class="auth-form" id="signupForm">
        <div class="field">
          <label>Email</label>
          <input class="input" id="email" type="email" autocomplete="email" placeholder="you@example.com" required />
        </div>
        <div class="field">
          <label>Password</label>
          <input class="input" id="password" type="password" autocomplete="new-password" placeholder="At least 8 characters" required minlength="8" />
        </div>
        <div class="field">
          <label>Confirm password</label>
          <input class="input" id="password2" type="password" autocomplete="new-password" placeholder="Re-enter password" required minlength="8" />
        </div>
        <div class="error-text" id="errorText"></div>
        <button class="btn btn-primary btn-block" id="submitBtn" type="submit">Create account</button>
      </form>
      <p class="auth-foot-note">
        Every account gets <strong><%= freeMonthlyCredits %> free receipt generates a month</strong>. Need more?
        Email <a href="mailto:kapeairzz7@gmail.com">kapeairzz7@gmail.com</a> and we'll top you up.
      </p>
    </div>
  </div>
  <script src="/public/js/common.js"></script>
  <script src="/public/js/signup.js"></script>
</body>
</html>
